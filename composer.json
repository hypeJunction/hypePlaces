    "description": "Directory of Businesses, Places of Interests and Private Locations",
    "homepage": "https://github.com/hypeJunction/hypePlaces",
    "keywords": [
        "elgg",
        "plugin",
        "places",
        "maps",
        "directory"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "extra": {
